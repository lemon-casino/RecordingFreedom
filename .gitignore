.DS_Store
Thumbs.db

# Local environment
.env
.env.*
!.env.example

# Logs and temporary output
*.log
*.tmp
*.out
*.test
coverage/

# Wails / Go build output
app/.task/
app/bin/

# Wails desktop build assets are required for CI/release builds.
!app/build/
!app/build/Taskfile.yml
!app/build/config.yml
!app/build/appicon.png
!app/build/icons/
!app/build/icons/**
!app/build/docker/
!app/build/docker/**
!app/build/darwin/
!app/build/darwin/**
!app/build/linux/
!app/build/linux/**
!app/build/windows/
!app/build/windows/**
app/build/android/
app/build/ios/

# App-managed local data
app/data/*
!app/data/
!app/data/video/
!app/data/video/.gitkeep

# Frontend build and local tooling output
app/frontend/dist/
app/frontend/node_modules/
!app/frontend/package-lock.json
app/frontend/.codex-run/
app/frontend/capsule-preview.png
app/frontend/vite-preview.log
app/frontend/playwright-report/
app/frontend/test-results/

# Platform packaging caches
app/build/linux/appimage/build/
app/build/windows/nsis/MicrosoftEdgeWebview2Setup.exe

# Downloaded native desktop tools
app/tools/*
!app/tools/
!app/tools/.gitkeep
!app/tools/THIRD_PARTY_NOTICES.txt

# Mobile generated files contain machine-local paths
app/build/ios/xcode/overlay.json
app/build/ios/xcode/gen/
app/build/android/overlay.json
app/build/android/gen/
