<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="recordingfreedom.exe"
        Arguments=""
        InstallLocation="C:\Program Files\lemon-casino\RecordingFreedom">
    </Installer>
    <PackageInformation
        PackageName="RecordingFreedom"
        PackageDisplayName="RecordingFreedom"
        PublisherName="CN=lemon-casino"
        PublisherDisplayName="lemon-casino"
        Version="0.1.2.0"
        PackageDescription="A modern capsule screen recorder built with Go, React, and Wails v3">
        <Capabilities>
            <Capability Name="runFullTrust" />

        </Capabilities>
        <Applications>
            <Application
                Id="casino.lemon.recordingfreedom"
                Description="A modern capsule screen recorder built with Go, React, and Wails v3"
                DisplayName="RecordingFreedom"
                ExecutableName="recordingfreedom.exe"
                EntryPoint="Windows.FullTrustApplication">

            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>RecordingFreedom</DisplayName>
            <PublisherDisplayName>lemon-casino</PublisherDisplayName>
            <Description>A modern capsule screen recorder built with Go, React, and Wails v3</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="recordingfreedom.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
